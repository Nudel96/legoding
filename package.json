{
  "name": "lego-deal-finder",
  "version": "1.0.0",
  "description": "LEGO Star Wars Deal Finder Agent — automated deal discovery via eBay & BrickLink APIs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "seed": "tsx src/scripts/seedSearchJobs.ts"
  },
  "keywords": ["lego", "star-wars", "deal-finder", "ebay", "bricklink"],
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "express": "^4.21.0",
    "dotenv": "^16.4.5",
    "crypto-js": "^4.2.0",
    "oauth-1.0a": "^2.2.6",
    "googleapis": "^144.0.0",
    "winston": "^3.14.0",
    "@google-cloud/firestore": "^7.10.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/express": "^5.0.0",
    "@types/crypto-js": "^4.2.0",
    "@types/uuid": "^10.0.0"
  }
}
