PORT=8080
NODE_ENV=development

# Google Cloud
GOOGLE_CLOUD_PROJECT=
FIRESTORE_DATABASE=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SHEETS_REVIEW_SPREADSHEET_ID=

# eBay Browse API
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_DE
EBAY_BASE_URL=https://api.ebay.com

# BrickLink API (OAuth 1.0a)
BRICKLINK_CONSUMER_KEY=
BRICKLINK_CONSUMER_SECRET=
BRICKLINK_TOKEN_VALUE=
BRICKLINK_TOKEN_SECRET=

# Rebrickable (optional)
REBRICKABLE_API_KEY=

# Gemini AI (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Notifications
NOTIFICATION_MODE=none
GOOGLE_CHAT_WEBHOOK_URL=
GMAIL_NOTIFICATION_TO=

# Deal Scoring
MIN_DEAL_SCORE_NOTIFY=80
DEFAULT_CURRENCY=EUR
DEFAULT_REGION=EU
DEFAULT_COUNTRY=DE
